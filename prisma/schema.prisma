generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────

enum StatutArticle {
  PENDING
  DRAFT
  PUBLISHED
  REJECTED
}

enum StatutAvis {
  PENDING
  APPROVED
  REJECTED
}

enum SocialQueueStatut {
  PENDING
  DONE
  ERROR
}

enum RoleAdmin {
  SUPER_ADMIN
  EDITEUR
}

// ─── Models ───────────────────────────────────────────────

model SiteConfig {
  id     String @id @default(cuid())
  cle    String @unique
  valeur String @db.Text

  @@map("site_config")
}

model Categorie {
  id       String    @id @default(cuid())
  nom      String
  slug     String    @unique
  couleur  String    // code hex couleur du tag
  ordre    Int       @default(0)
  articles Article[]

  @@map("categories")
}

model Article {
  id              String        @id @default(cuid())
  titre           String
  slug            String        @unique
  chapo           String        @db.Text
  contenu         String        @db.Text
  imageUrl        String?
  imageAlt        String?
  categorieId     String
  categorie       Categorie     @relation(fields: [categorieId], references: [id])
  sousCategorie   String?
  tags            String[]
  sourceUrl       String
  sourceNom       String
  statut          StatutArticle @default(PENDING)
  auteur          String        @default("Réalitte IA")
  vues            Int           @default(0)
  tempsLecture    Int?          // minutes
  scoreSeo        Int?
  metaTitle       String?
  metaDescription String?
  featured          Boolean       @default(false)
  featuredCategorie Boolean       @default(false)
  imageClean        Boolean       @default(false)
  dateCreation    DateTime      @default(now())
  datePublication DateTime?
  scheduledFor    DateTime?
  avis            Avis[]
  socialQueue     SocialQueueItem[]

  @@index([statut, datePublication])
  @@index([statut, scheduledFor])
  @@index([categorieId, statut])
  @@index([categorieId, featuredCategorie])
  @@index([slug])
  @@map("articles")
}

model SourceBrute {
  id             String   @id @default(cuid())
  url            String
  titreOriginal  String
  contenuBrut    String   @db.Text
  categorie      String?
  dateCollecte   DateTime @default(now())
  traite         Boolean  @default(false)
  erreur         String?

  @@index([traite])
  @@index([traite, categorie])
  @@map("sources_brutes")
}

model Avis {
  id           String     @id @default(cuid())
  articleId    String
  article      Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  auteurNom    String
  email        String?
  note         Int?
  commentaire  String     @db.Text
  statut       StatutAvis @default(PENDING)
  dateCreation DateTime   @default(now())

  @@index([articleId, statut])
  @@map("avis")
}

model AbonneNewsletter {
  id              String   @id @default(cuid())
  email           String   @unique
  dateInscription DateTime @default(now())
  actif           Boolean  @default(true)

  @@map("abonnes_newsletter")
}

model AdminUser {
  id              String    @id @default(cuid())
  email           String    @unique
  motDePasseHash  String
  nom             String?
  role            RoleAdmin @default(EDITEUR)
  actif           Boolean   @default(true)
  dateCreation    DateTime  @default(now())
  derniereConnexion DateTime?

  @@map("admin_users")
}

model EspacePartenaire {
  id        String  @id @default(cuid())
  actif     Boolean @default(true)
  titre     String
  sousTitre String?
  imageUrl  String?
  lien      String?
  ctaTexte  String  @default("EN SAVOIR PLUS")
  position  String  @default("home")
  ordre     Int     @default(0)
  clics     Int     @default(0)
  padding   Int     @default(4)

  @@map("espace_partenaire")
}

model EntrepreneurSemaine {
  id                   String   @id @default(cuid())
  entrepreneurNom      String
  entrepreneurTitre    String
  entrepreneurBio      String   @db.Text
  entrepreneurCitation String   @db.Text
  entrepreneurPhoto    String?
  entrepriseNom        String
  entrepriseDescription String  @db.Text
  entrepriseLogo       String?
  entrepriseSite       String?
  semaineDu            DateTime
  actif                Boolean  @default(true)
  dateCreation         DateTime @default(now())

  @@map("entrepreneur_semaine")
}

model SocialQueueItem {
  id          String            @id @default(cuid())
  articleId   String
  article     Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)
  network     String
  message     String            @db.Text
  imageUrl    String?
  statut      SocialQueueStatut @default(PENDING)
  scheduledAt DateTime
  processedAt DateTime?
  erreur      String?
  createdAt   DateTime          @default(now())

  @@index([statut, scheduledAt])
  @@map("social_queue_items")
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

model PipelineLog {
  id          String   @id @default(cuid())
  type        String   // collect | generate | error
  message     String   @db.Text
  metadata    Json?
  dateCreation DateTime @default(now())

  @@index([type, dateCreation])
  @@map("pipeline_logs")
}
